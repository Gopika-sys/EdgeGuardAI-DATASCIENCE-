# EdgeGuard AI Backend — environment variables
# ================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored — it will NEVER be committed or pushed to GitHub.
#
# All variables are OPTIONAL in v2.1+. The backend is self-contained:
#   • If SUPABASE_* are missing, the backend uses local SQLite (edgeguard.db).
#   • If MQTT is unreachable, a built-in sensor simulator drives the dashboard.
#   • If ML models are missing, a built-in predictor is used.
# This means the demo NEVER breaks on a laptop with no internet.
#
# Get the Supabase values from: Supabase dashboard → Project Settings → API
# The "secret" key starts with sb_secret_ in newer Supabase projects.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_KEY=sb_secret_YOUR-KEY-HERE

# MQTT — defaults are the public broker (works for the Wokwi sim).
# If your network blocks it, the backend will fall back to simulation.
# MQTT_BROKER=broker.hivemq.com
# MQTT_PORT=1883
# MQTT_TOPIC_FILTER=edgeguard/+/+

# Demo / simulation controls (auto | on | off)
# DEMO_ENABLED=auto
# DEMO_TRUCK_ID=truck1
